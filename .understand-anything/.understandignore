*.pyc
*.pyo
*.pyd
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / build output ---
node_modules/
dist/
build/
out/
.next/
.turbo/
.parcel-cache/

# --- VCS / tooling data dirs ---
.git/
.gitnexus/
.understand-anything/
.ua/
.project-intel/cache/
.project-intel/tmp/
.project-intel/local/
.cache/

