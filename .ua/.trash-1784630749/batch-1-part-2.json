        "scanner",
        "frontend",
        "vue",
        "react",
        "static-analysis"
      ],
      "complexity": "complex",
      "languageNotes": "extract_object_argument_blocks 用括号深度计数解析嵌套对象字面量，兼容 defineProps/defineEmits 等 Vue 编译宏。"
