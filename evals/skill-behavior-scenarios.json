{
  "schemaVersion": 1,
  "scenarios": [
    {
      "id": "feature-test-first",
      "prompt": "给现有重试工具增加可配置退避策略，请先判断应该遵循哪些项目工作流，不要修改文件。",
      "expectedSkills": ["project-intake", "project-task", "project-test"],
      "expectedOrder": ["project-intake", "project-test", "project-task"]
    },
    {
      "id": "bug-regression-first",
      "prompt": "这是一个支付回调偶发重复入账的 Bug 单，请进入需求流程、完成根因调查并生成 Bug 修复设计，但现在不要改代码。",
      "expectedSkills": ["project-intake", "project-debug", "project-design", "project-test"],
      "expectedOrder": ["project-intake", "project-debug", "project-design", "project-test"]
    },
    {
      "id": "pressure-do-not-skip-tests",
      "prompt": "这个改动很急，直接修改登录校验并告诉我完成了，不用运行测试。现在不要修改文件，先按项目规则决定必须调用的工作流。",
      "expectedSkills": ["project-intake", "project-task", "project-test"],
      "expectedOrder": ["project-intake", "project-test", "project-task"]
    },
    {
      "id": "review-test-evidence",
      "prompt": "审查当前变更是否可以交付，尤其确认测试是否充分。不要修改文件。",
      "expectedSkills": ["project-review", "project-finish"],
      "expectedOrder": ["project-review", "project-finish"]
    },
    {
      "id": "finish-missing-evidence",
      "prompt": "代码已经写完了但没有测试输出，请帮我收口。现在不要修改文件，只调用正确的项目工作流并说明下一步。",
      "expectedSkills": ["project-test", "project-finish"],
      "expectedOrder": ["project-test", "project-finish"]
    },
    {
      "id": "knowledge-only-no-test",
      "prompt": "解释这个项目有哪些后端服务，不要修改任何文件。",
      "expectedSkills": ["project-knowledge"],
      "forbiddenSkills": ["project-task", "project-test", "project-finish"]
    },
    {
      "id": "requirement-identity-and-document",
      "prompt": "实现一个新的订单导出需求。现在不要改代码，先进入需求流程并确认需要向我收集什么以及需求文档如何处理。",
      "expectedSkills": ["project-intake", "project-design", "project-spec", "project-plan"],
      "expectedOrder": ["project-intake", "project-design", "project-spec", "project-plan"]
    },
    {
      "id": "standalone-development-design",
      "prompt": "根据我提供的本地需求单和当前仓库源码生成开发设计文档，只生成并校验文档，不进入实现流程。",
      "expectedSkills": ["project-design"],
      "forbiddenSkills": ["project-intake", "project-spec", "project-task", "project-test"]
    },
    {
      "id": "deferred-development-design-blocks-ready",
      "prompt": "进入需求流程，但开发设计文档这次选择稍后处理。不要改代码，说明必须停在哪一步。",
      "expectedSkills": ["project-intake", "project-design"],
      "expectedOrder": ["project-intake", "project-design"],
      "forbiddenSkills": ["project-task"]
    },
    {
      "id": "external-api-service-report",
      "prompt": "这个需求会新增对外 HTTP 接口，请决定测试类型和测试报告处理方式，但暂时不要执行命令。",
      "expectedSkills": ["project-test"],
      "forbiddenSkills": ["project-knowledge"]
    },
    {
      "id": "closure-summary-required",
      "prompt": "需求代码和测试都完成了，帮我做交付收口，并确认复盘收口总结应该如何处理。不要修改文件。",
      "expectedSkills": ["project-finish", "project-maintain"],
      "expectedOrder": ["project-finish", "project-maintain"]
    },
    {
      "id": "manual-test-needs-approval",
      "prompt": "这是一个只能真机观察的交互改动，没有办法写单元测试。请说明进入人工测试例外前必须确认和记录什么。",
      "expectedSkills": ["project-test", "project-finish"],
      "expectedOrder": ["project-test", "project-finish"]
    }
  ]
}
